expression 'DirectLake - lh_Finance_Silver' =
		let
		    Source = AzureStorage.DataLake("https://onelake.dfs.fabric.microsoft.com/<WORKSPACE_ID>/<LAKEHOUSE_ID>", [HierarchicalNavigation=true])
		in
		    Source
	lineageTag: b1c2d3e4-f5a6-7890-bcde-fa1234567801

	annotation PBI_IncludeFutureArtifacts = False

// ⚠ BEFORE FABRIC SYNC: Replace <WORKSPACE_ID> and <LAKEHOUSE_ID> above
// with the real GUIDs from your lh_Finance_Silver lakehouse.
// Find them in Fabric → lh_Finance_Silver → Settings → About → Copy IDs.
// Format:
//   Workspace ID: 39caa3ab-xxxx-xxxx-xxxx-xxxxxxxxxxxx
//   Lakehouse ID: fda3c40e-xxxx-xxxx-xxxx-xxxxxxxxxxxx
// Then delete these comment lines.
