table gold_dim_product

	column ProductID
		dataType: int64
		isKey
		summarizeBy: none
		sourceColumn: ProductID

	column ProductName
		dataType: string
		sourceColumn: ProductName

	column ProductNumber
		dataType: string
		sourceColumn: ProductNumber

	column Color
		dataType: string
		sourceColumn: Color

	column ListPrice
		dataType: decimal
		formatString: $#,##0.00
		summarizeBy: none
		sourceColumn: ListPrice

	column ProductCategoryID
		dataType: int64
		summarizeBy: none
		sourceColumn: ProductCategoryID

	column CategoryName
		dataType: string
		sourceColumn: CategoryName

	partition gold_dim_product = entity
		mode: directLake
		source
			entityName: gold_dim_product
			schemaName: dbo
			expressionSource: 'DirectLake - lh_AdventureWorks'

